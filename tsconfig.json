{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./lib",
    "module": "node16",
    "target": "es2018",
    "types": [],
    "declaration": true,
    // "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
